            subprocess.run(["python3", str(BASE / "tools/opencog/atomspace.py")] + rest)
        elif sub == "pln":
            subprocess.run(["python3", str(BASE / "tools/opencog/pln.py")] + rest)
        elif sub == "ecan":
            subprocess.run(["python3", str(BASE / "tools/opencog/ecan.py")] + rest)
        elif sub == "seed":
            # Seed all knowledge into AtomSpace
            from tools.opencog.atomspace import get_atomspace
            from tools.opencog.pln import PLNEngine
            from tools.opencog.ecan import get_ecan
            as_ = get_atomspace()
            n1  = as_.ingest_from_knowledge_graph()
            pln = PLNEngine(as_)
            n2  = pln.seed_security_knowledge()
            n3  = pln.seed_market_knowledge()
            ecan = get_ecan()
            n4  = ecan.seed_from_history()
            print(f"AtomSpace seeded: {n1} graph nodes, {n2} security, {n3} market atoms")
            print(f"ECAN seeded: {n4} attention signals from history")
            as_.close(); ecan.close()
        else:
            print("Usage: nova opencog [atomspace|pln|ecan|seed] [args]")

