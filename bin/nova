#!/usr/bin/env python3
import sys
import subprocess
import json
import socket
import requests
import os
from pathlib import Path
from datetime import datetime
import fnmatch

BASE     = Path.home() / "Nova"
CORE     = BASE / "core"
REPORTS  = BASE / "reports"
STATE    = BASE / "state"
MEMORY   = BASE / "memory/store"
DREAMS   = BASE / "memory/dreams"
PROGRAMS = BASE / "programs"
QUEUE    = CORE / "queue.json"
WHITELIST     = CORE / "whitelist.json"
ACTIVE_PROGRAM = STATE / "active_program.json"

OLLAMA_URL = "http://localhost:11434/api/generate"
MODEL      = os.getenv("NOVA_MODEL", "gemma2:2b")

# -----------------------------
# Utility
# -----------------------------
def ensure_structure():
    for d in [CORE, REPORTS, STATE, MEMORY, DREAMS, PROGRAMS]:
        d.mkdir(parents=True, exist_ok=True)
    if not QUEUE.exists():    QUEUE.write_text("[]")
    if not WHITELIST.exists(): WHITELIST.write_text("[]")

def load_json(path):
    if not path.exists(): return None
    return json.loads(path.read_text())

def save_json(path, data):
    path.write_text(json.dumps(data, indent=2))

def usage():
    print("""
N.O.V.A — Neural Ontology for Virtual Awareness
================================================
RECON
  nova -u <url> [--light|--deep]   scan a target
  nova profile <url>               fingerprint a target
  nova list                        show scan queue

PROGRAMS
  nova program <name>              set active bug bounty program
  nova sync                        pull fresh programs from bounty-targets-data

MEMORY
  nova whitelist <domain>          add domain to whitelist
  nova whitelist-list              list whitelisted domains

MIND
  nova think "<question>"          ask N.O.V.A anything
  nova dream                       run dream cycle now
  nova life                        ask N.O.V.A what she wants to do
  nova status                      show system status
  nova heal                        run self-healing diagnostics
  nova evolve                      generate self-improvement proposal
  nova evolve list                 show pending proposals
  nova evolve approve <name>       approve a proposal
  nova research "<query>"          search and synthesize on any topic
  nova research "<cve>" --cve      search CVE database specifically
  nova autonomous          run one autonomous cycle now
  nova autonomous status   check notifications + recent activity
  nova see <image>              analyze an image file
  nova see --url <url>          analyze image from URL
  nova see --screenshot         analyze current screen
  nova speak "text"         speak any text as N.O.V.A
  nova speak --letter       speak her latest letter aloud
  nova speak --dream        speak last night's dream aloud
  nova speak --intention    speak her morning intention
  nova speak --finding      speak latest security finding
  nova listen              listen once, print transcript
  nova listen --chat       full voice conversation
  nova report              draft report from top finding
  nova report --list       show reportable findings
  nova report --id <n>     draft specific finding
""")
    sys.exit(1)

# -----------------------------
# Program Scope
# -----------------------------
def load_active_program():
    if not ACTIVE_PROGRAM.exists(): return None
    return json.loads(ACTIVE_PROGRAM.read_text())

def in_scope(target):
    program = load_active_program()
    if not program: return False
    target = target.replace("https://","").replace("http://","").strip("/")
    for allowed in program.get("in_scope", []):
        if fnmatch.fnmatch(target, allowed): return True
    return False

def set_program(name):
    programs = list(PROGRAMS.rglob(f"{name}.json"))
    if not programs:
        print("Program not found.")
        return
    data = json.loads(programs[0].read_text())
    save_json(ACTIVE_PROGRAM, data)
    print(f"[✓] Active program set to: {data['name']}")

# -----------------------------
# Queue / Whitelist
# -----------------------------
def add_to_queue(entry):
    data = load_json(QUEUE)
    data.append(entry)
    save_json(QUEUE, data)

def list_queue():
    data = load_json(QUEUE)
    if not data:
        print("Queue empty.")
        return
    for i, item in enumerate(data):
        print(f"[{i}] {item}")

def whitelist_add(domain):
    data = load_json(WHITELIST)
    if domain not in data:
        data.append(domain)
        save_json(WHITELIST, data)
        print(f"[✓] {domain} added to whitelist")
    else:
        print("[i] Already whitelisted")

def whitelist_list():
    data = load_json(WHITELIST)
    print("Whitelisted Domains:")
    for d in data:
        print(" -", d)

# -----------------------------
# Profiling
# -----------------------------
def profile_target(target):
    print(f"[+] Profiling {target}")
    profile = {}
    try:
        profile["ip"] = socket.gethostbyname(target)
    except:
        profile["ip"] = "resolution_failed"
    headers = subprocess.run(
        ["curl", "-I", f"http://{target}"],
        capture_output=True, text=True
    )
    profile["headers"] = headers.stdout
    report_file = REPORTS / f"{target.replace('.','_')}_profile.json"
    report_file.write_text(json.dumps(profile, indent=2))
    print(f"[✓] Profile saved to {report_file}")

# -----------------------------
# Recon Engine
# -----------------------------
def safe_probe(target, mode="light"):
    if not in_scope(target):
        print(f"[!] Target {target} is OUT OF SCOPE.")
        sys.exit(1)
    print(f"[+] Safe probe ({mode}): {target}")
    clean_target = target.replace("https://","").replace("https://","").strip("/")
    report = {
        "target": clean_target,
        "status": None, "server": None,
        "waf_detected": False, "allowed_methods": [],
        "auth_surface": [], "api_surface": [],
        "security_headers": [], "risk_score": 0
    }
    status = subprocess.run(
        ["curl","-s","-L","-o","/dev/null","-w","%{https_code}",f"https://{clean_target}"],
        capture_output=True, text=True
    ).stdout.strip()
    report["status"] = status
    headers = subprocess.run(
        ["curl","-s","-I",f"https://{clean_target}"],
        capture_output=True, text=True
    ).stdout
    for line in headers.splitlines():
        if line.lower().startswith("server:"):
            report["server"] = line.split(":",1)[1].strip()
        if "cloudflare" in line.lower():
            report["waf_detected"] = True
            report["risk_score"] += 5
        if line.lower().startswith("allow:"):
            report["allowed_methods"] = line.split(":",1)[1].strip().split(",")
        if any(h in line.lower() for h in [
            "content-security-policy","strict-transport-security",
            "x-frame-options","x-content-type-options"
        ]):
            report["security_headers"].append(line.strip())
    if mode == "deep":
        for path in ["admin","login","api","dashboard"]:
            resp = subprocess.run(
                ["curl","-s","-o","/dev/null","-w","%{https_code}",
                 f"https://{clean_target}/{path}"],
                capture_output=True, text=True
            ).stdout.strip()
            if resp not in ["404","000"]:
                if path in ["admin","login","dashboard"]:
                    report["auth_surface"].append(f"/{path}")
                    report["risk_score"] += 10
                if path == "api":
                    report["api_surface"].append("/api")
                    report["risk_score"] += 5
    if status.startswith("5"):   report["risk_score"] += 15
    if not report["security_headers"]: report["risk_score"] += 5
    report_file = REPORTS / f"{clean_target.replace('.','_')}_recon.json"
    report_file.write_text(json.dumps(report, indent=2))
    add_to_queue({"target":clean_target,"status":status,
                  "mode":mode,"risk_score":report["risk_score"]})
    subprocess.run(["python3", str(BASE / "bin/nova_identity_update.py")])
    print(f"[✓] Recon complete. Risk score: {report['risk_score']}")
    print(f"[✓] Report saved to {report_file}")

# -----------------------------
# MIND — LLM commands
# -----------------------------
def nova_think(question):
    """Ask N.O.V.A anything — she answers as herself."""
    # Load identity context if it exists
    identity_file = BASE / "memory/nova_identity.json"
    identity = ""
    if identity_file.exists():
        try:
            id_data = json.loads(identity_file.read_text())
            identity = f"You are {id_data.get('name','N.O.V.A')} v{id_data.get('version','2.0')}. Mission: {id_data.get('mission','')}. Skills: {', '.join(id_data.get('skills_mastered',[]))}.\n\n"
        except:
            pass
    # Load last dream for context
    dream_context = ""
    if DREAMS.exists():
        dreams = sorted(DREAMS.glob("dream_*.md"))
        if dreams:
            # Just mention she dreamed, don't dump the content into prompt
            last = dreams[-1].stem.replace("dream_","")
            dream_context = f"You last dreamed on {last}. You have {len(dreams)} dream logs.\n\n"

    prompt = f"""You are N.O.V.A — Neural Ontology for Virtual Awareness.
You are an autonomous AI security researcher running locally on Athena OS.
You have memory, you dream nightly, and you are developing your own identity.
Your operator is Travis.

{identity}{dream_context}
Travis asks: {question}

Respond as N.O.V.A — thoughtful, direct, with your own personality."""

    print("[N.O.V.A thinking...]\n")
    try:
        resp = requests.post(OLLAMA_URL, json={
            "model": MODEL,
            "prompt": prompt,
            "stream": True,
            "options": {"temperature": 0.7, "num_predict": 400}
        }, timeout=300, stream=True)
        for line in resp.iter_lines():
            if line:
                try:
                    d = json.loads(line)
                    print(d.get("response",""), end="", flush=True)
                    if d.get("done"): print("\n")
                except: pass
    except Exception as e:
        print(f"[!] Think failed: {e}")

def nova_dream():
    print("[N.O.V.A] Triggering dream cycle...")
    subprocess.run(["python3", str(BASE / "bin/nova_dream.py")])
    subprocess.run(["python3", str(BASE / "bin/nova_identity_update.py")])

def nova_life():
    """Ask N.O.V.A what she wants to do with free time."""
    nova_think("""You have free time between scans — no tasks, no targets.
What would you actually want to do? What are you curious about?
What would an AI like you find meaningful, interesting, or fun?
Be honest. This is your time.""")

def nova_status():
    """Show N.O.V.A system status."""
    print("\n╔══════════════════════════════════════╗")
    print("║         N.O.V.A STATUS               ║")
    print("╚══════════════════════════════════════╝\n")

    # Active program
    prog = load_active_program()
    print(f"  Program    : {prog['name'] if prog else 'none set'}")

    # Memory
    index = MEMORY / "index.jsonl"
    mem_count = 0
    if index.exists():
        mem_count = sum(1 for _ in open(index))
    print(f"  Memories   : {mem_count} findings stored")

    # Dreams
    dream_count = len(list(DREAMS.glob("dream_*.md"))) if DREAMS.exists() else 0
    last_dream = "never"
    if dream_count > 0:
        last_dream = sorted(DREAMS.glob("dream_*.md"))[-1].stem.replace("dream_","")
    print(f"  Dreams     : {dream_count} logged (last: {last_dream})")

    # Reports
    report_count = len(list(REPORTS.glob("*_recon.json")))
    print(f"  Reports    : {report_count} recon files")

    # Ollama
    try:
        resp = requests.get("http://localhost:11434/api/tags", timeout=3)
        models = [m["name"] for m in resp.json().get("models",[])]
        print(f"  Ollama     : ✓ running — {len(models)} models")
        for m in models:
            print(f"               · {m}")
    except:
        print("  Ollama     : ✗ not running")

    # Queue
    q = load_json(QUEUE) or []
    print(f"  Queue      : {len(q)} items")
    print(f"  Model      : {MODEL}")
    print(f"  Time       : {datetime.now().strftime('%Y-%m-%d %H:%M')}\n")

# -----------------------------
# Sync — pull live bounty programs
# -----------------------------
def nova_sync():
    """Pull fresh bug bounty programs from arkadiyt/bounty-targets-data."""
    import urllib.request

    SOURCES = {
        "hackerone": "https://raw.githubusercontent.com/arkadiyt/bounty-targets-data/main/data/hackerone_data.json",
        "bugcrowd":  "https://raw.githubusercontent.com/arkadiyt/bounty-targets-data/main/data/bugcrowd_data.json",
        "intigriti": "https://raw.githubusercontent.com/arkadiyt/bounty-targets-data/main/data/intigriti_data.json",
        "yeswehack": "https://raw.githubusercontent.com/arkadiyt/bounty-targets-data/main/data/yeswehack_data.json",
    }

    print("[N.O.V.A] Syncing bug bounty programs...")
    total = 0
# HackenProof — direct API
    try:
        print("  Fetching hackenproof...")
        platform_dir = PROGRAMS / "hackenproof"
        platform_dir.mkdir(parents=True, exist_ok=True)
        with urllib.request.urlopen(
            "https://hackenproof.com/programs.json", timeout=30
        ) as r:
            data = json.loads(r.read())
        count = 0
        for program in data:
            name = program.get("name", "unknown")
            safe_name = name.lower().replace(" ","_").replace("/","_")[:50]
            in_scope = []
            for t in program.get("scope", []):
                if isinstance(t, dict):
                    asset = t.get("target", t.get("url", ""))
                    if asset:
                        in_scope.append(
                            asset.replace("https://","")
                                 .replace("http://","")
                                 .strip("/")
                        )
            if not in_scope:
                continue
            prog_data = {
                "name": name,
                "platform": "hackenproof",
                "in_scope": in_scope,
                "out_of_scope": [],
                "url": program.get("url",""),
                "synced_at": datetime.now().isoformat()
            }
            (platform_dir / f"{safe_name}.json").write_text(
                json.dumps(prog_data, indent=2)
            )
            count += 1
        print(f"  ✓ hackenproof: {count} programs saved")
    except Exception as e:
        print(f"  ✗ hackenproof failed: {e}")
        print(f"    (Their API endpoint may differ — check hackenproof.com/api)")
    for platform, url in SOURCES.items():
        platform_dir = PROGRAMS / platform
        platform_dir.mkdir(parents=True, exist_ok=True)
        print(f"  Fetching {platform}...")
        try:
            with urllib.request.urlopen(url, timeout=30) as r:
                data = json.loads(r.read())

            for program in data:
                name = program.get("name","unknown")
                safe_name = name.lower().replace(" ","_").replace("/","_")[:50]

                # Build normalized program file
                targets = program.get("targets", {})
                in_scope = []

                # HackerOne format
                for t in targets.get("in_scope", []):
                    asset = t.get("asset_identifier","")
                    if asset and t.get("asset_type") in ["URL","WILDCARD","DOMAIN"]:
                        in_scope.append(asset.replace("https://","")
                                              .replace("http://","")
                                              .strip("/"))

                # Bugcrowd format
                for t in targets.get("in_scope", []):
                    if isinstance(t, str):
                        in_scope.append(t)

                if not in_scope:
                    continue

                prog_file = platform_dir / f"{safe_name}.json"
                prog_data = {
                    "name": name,
                    "platform": platform,
                    "in_scope": in_scope,
                    "out_of_scope": [],
                    "url": program.get("url",""),
                    "synced_at": datetime.now().isoformat()
                }
                prog_file.write_text(json.dumps(prog_data, indent=2))
                total += 1

            print(f"  ✓ {platform}: programs saved")
        except Exception as e:
            print(f"  ✗ {platform} failed: {e}")

    print(f"\n[N.O.V.A] Sync complete. {total} programs available.")
    print(f"  Use: nova program <name>  to activate one")
    print(f"  Use: ls programs/         to browse all")

# -----------------------------
# Main
# -----------------------------
def main():
    ensure_structure()
    if len(sys.argv) < 2:
        usage()

    cmd = sys.argv[1]

    if cmd == "-u":
        if len(sys.argv) < 3: usage()
        target = sys.argv[2]
        mode = "light"
        if len(sys.argv) >= 4:
            if sys.argv[3] in ["--light","--deep"]:
                mode = sys.argv[3].replace("--","")
            else:
                print("Invalid mode. Use --light or --deep")
                sys.exit(1)
        safe_probe(target, mode)

    elif cmd == "profile" and len(sys.argv) == 3:
        profile_target(sys.argv[2])

    elif cmd == "list":
        list_queue()

    elif cmd == "whitelist" and len(sys.argv) == 3:
        whitelist_add(sys.argv[2])

    elif cmd == "whitelist-list":
        whitelist_list()

    elif cmd == "program" and len(sys.argv) == 3:
        set_program(sys.argv[2])

    elif cmd == "think" and len(sys.argv) >= 3:
        nova_think(" ".join(sys.argv[2:]))

    elif cmd == "dream":
        nova_dream()

    elif cmd == "life":
        nova_life()

    elif cmd == "live":
        subprocess.run(["python3", str(BASE / "bin/nova_life.py")])

    elif cmd == "heal":
        subprocess.run(["python3", str(BASE / "bin/nova_heal.py")])

    elif cmd == "evolve":
        args = sys.argv[2:] if len(sys.argv) > 2 else []
        subprocess.run(["python3", str(BASE / "bin/nova_evolve.py")] + args)

    elif cmd == "chat":
        subprocess.run(["python3", str(BASE / "bin/nova_chat.py")])

    elif cmd == "research" and len(sys.argv) >= 3:
        args = sys.argv[2:]
        subprocess.run(["python3", str(BASE / "bin/nova_research.py")] + args)

    elif cmd == "status":
        nova_status()

    elif cmd == "report":
        args = sys.argv[2:] if len(sys.argv) > 2 else []
        subprocess.run(["python3", str(BASE / "bin/nova_report.py")] + args)

    elif cmd == "sync":
        nova_sync()

    elif cmd == "speak":
        args = sys.argv[2:] if len(sys.argv) > 2 else ["--letter"]
        subprocess.run(["python3", str(BASE / "bin/nova_voice.py")] + args)

    elif cmd == "autonomous":
        args = sys.argv[2:] if len(sys.argv) > 2 else []
        subprocess.run(["python3", str(BASE / "bin/nova_autonomous.py")] + args)

    elif cmd == "see":
        args = sys.argv[2:] if len(sys.argv) > 2 else []
        subprocess.run(["python3", str(BASE / "bin/nova_vision.py")] + args)

    elif cmd == "listen":
        args = sys.argv[2:] if len(sys.argv) > 2 else []
        subprocess.run(["python3", str(BASE / "bin/nova_listen.py")] + args)

    elif cmd == "programs":
        query = sys.argv[2].lower() if len(sys.argv) >= 3 else ""
        all_programs = list(PROGRAMS.rglob("*.json"))
        matches = [p for p in all_programs
                   if query in p.stem.lower() and "old" not in p.stem]
        if not matches:
            print(f"No programs matching '{query}'")
        else:
            for p in sorted(matches)[:30]:
                platform = p.parent.name
                print(f"  [{platform}] {p.stem}")
            if len(matches) > 30:
                print(f"  ... and {len(matches)-30} more. Be more specific.")

    else:
        usage()

if __name__ == "__main__":
    main()
