        sub  = sys.argv[2] if len(sys.argv) > 2 else "--help"
        rest = sys.argv[3:] if len(sys.argv) > 3 else []

        if sub == "install-udev":
            # Install udev rule so USB auto-launches Nova on insertion
            udev_src  = BASE / "tools/os/plugin/nova-udev.rules"
            udev_dest = Path("/etc/udev/rules.d/99-nova.rules")
            if udev_src.exists():
                subprocess.run(["sudo", "cp", str(udev_src), str(udev_dest)])
                subprocess.run(["sudo", "udevadm", "control", "--reload-rules"])
                print(f"\033[32mUdev rule installed. USB will auto-launch Nova when inserted.\033[0m")
            else:
                print("Build the USB first to generate udev rules.")
        elif sub == "detect":
            # Run the plugin detector locally (test plugin mode)
            detect = BASE / "tools/os/plugin/nova_detect.py"
            if detect.exists():
                subprocess.run(["python3", str(detect)])
            else:
                print("Plugin files not built yet. Run: nova usb --iso first.")
        else:
            args = [sub] + rest
            subprocess.run(["sudo", "bash", str(BASE / "tools/os/build_usb.sh")] + args)

